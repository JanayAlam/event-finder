{
  "name": "bhalo-thaki",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development nodemon",
    "clean": "rm -rf .next && rm -rf ./dist && rm -f ./tsconfig.tsbuildinfo",
    "build:next": "next build",
    "build:server": "tsc --project tsconfig.server.json",
    "build": "yarn clean && yarn run  build:server && yarn run build:next",
    "build:staging": "yarn clean && yarn run build:next:staging && yarn run build:server",
    "start": "NODE_ENV=production node dist/index.js",
    "lint": "eslint . --ext ts --ext tsx --ext js"
  },
  "engines": {
    "node": ">= 20.x",
    "npm": "please-use-yarn",
    "yarn": ">= 1.17.x"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.723.0",
    "@aws-sdk/lib-storage": "^3.723.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^6.1.0",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "next": "15.1.3",
    "nodemailer": "^6.9.16",
