{
  "name": "bhalo-thaki",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development nodemon",
    "clean": "rm -rf .next && rm -rf ./dist && rm -f ./tsconfig.tsbuildinfo",
    "build:next": "concurrently \"node scripts/start-server.js\" \"sleep 20 && next build && node scripts/kill-server.js\"",
    "build:server": "tsc --project tsconfig.server.json",
    "build": "yarn clean && yarn run build:next && yarn run build:server",
    "build:staging": "yarn clean && yarn run build:next:staging && yarn run build:server",
    "start": "NODE_ENV=production node dist/server/index.js",
    "lint": "eslint . --ext ts --ext tsx --ext js"
  },
  "engines": {
    "node": ">= 20.x",
    "npm": "please-use-yarn",
    "yarn": ">= 1.17.x"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "next": "15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "nodemon": "^3.1.9",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "packageManager": "yarn@1.22.22"
}
