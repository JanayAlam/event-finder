    "@tanstack/react-query": "^5.71.3",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "immer": "^10.1.1",
