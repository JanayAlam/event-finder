generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

enum USER_ROLE {
  SUPER_ADMIN
  OUTLET_ADMIN
  CUSTOMER
}

model User {
  id                 String              @id @default(cuid())
  firstName          String?
  lastName           String?
  email              String?             @unique
  phone              String?             @unique
  password           String?
  profilePhoto       String?
  isUserBlocked      Boolean             @default(false)
  role               USER_ROLE           @default(CUSTOMER)
  resetPasswordToken ResetPasswordToken?
  outlet             Outlet?
  updatedAt          DateTime            @updatedAt
  createdAt          DateTime            @default(now())
}

enum OTP_TYPE {
  LOGIN_EMAIL_OTP
  LOGIN_PHONE_OTP
}

model OTPDetails {
  id         String   @id @default(cuid())
  otpType    OTP_TYPE
  identifier String
  otp        String
  expireAt   DateTime
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model ResetPasswordToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  token     String
  expireAt  DateTime
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Outlet {
  id                 String         @id @default(cuid())
  name               String
  area               String?
  mapAddress         String
  addressDescription String?
  locationLongitude  Float
  locationLatitude   Float
  mapLink            String
  isActive           Boolean        @default(true)
  productBrands      ProductBrand[]
  outletAdmin        User           @relation(fields: [outletAdminId], references: [id])
  outletAdminId      String         @unique
  updatedAt          DateTime       @updatedAt
  createdAt          DateTime       @default(now())
}

model ProductBrand {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.LongText
  outlet      Outlet    @relation(fields: [outletId], references: [id])
  outletId    String
  products    Product[]
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
}

model ProductCategory {
  id               String            @id @default(cuid())
  parentCategory   ProductCategory?  @relation("ParentCategoryHistory", fields: [patentCategoryId], references: [id])
  patentCategoryId String?
  childCategories  ProductCategory[] @relation("ParentCategoryHistory")
  updatedAt        DateTime          @updatedAt
  createdAt        DateTime          @default(now())
}

model ProductSizeAndPrice {
  id        String   @id @default(cuid())
  title     String
  price     Decimal
  qty       Int
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Product {
  id                   String                @id @default(cuid())
  title                String
  subtitle             String?
  description          String?               @db.LongText
  SKU                  String?
  isFeatured           Boolean?
  isActive             Boolean?
  productPhoto         String?
  hasMultipleSizes     Boolean
  basePrice            Decimal?
  baseQty              Int?
  productBrand         ProductBrand?         @relation(fields: [productBrandId], references: [id])
  productBrandId       String?
  productSizeAndPrices ProductSizeAndPrice[]
  updatedAt            DateTime              @updatedAt
  createdAt            DateTime              @default(now())
}
