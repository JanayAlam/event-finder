generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

enum USER_ROLE {
  SUPER_ADMIN
  OUTLET_ADMIN
  CUSTOMER
}

model User {
  id                 String              @id @default(cuid())
  firstName          String?
  lastName           String?
  email              String?             @unique
  phone              String?             @unique
  password           String?
  profilePhoto       String?
  isUserBlocked      Boolean             @default(false)
  role               USER_ROLE           @default(CUSTOMER)
  resetPasswordToken ResetPasswordToken?
  outlet             Outlet?
  updatedAt          DateTime            @updatedAt
  createdAt          DateTime            @default(now())
}

enum OTP_TYPE {
  LOGIN_EMAIL_OTP
  LOGIN_PHONE_OTP
}

model OTPDetails {
  id         String   @id @default(cuid())
  otpType    OTP_TYPE
  identifier String
  otp        String
  expireAt   DateTime
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model ResetPasswordToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  token     String
  expireAt  DateTime
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Outlet {
  id                 String            @id @default(cuid())
  name               String
  area               String?
  mapAddress         String
  addressDescription String?
  locationLongitude  Float
  locationLatitude   Float
  mapLink            String
  isActive           Boolean           @default(true)
  productBrands      ProductBrand[]
  productCategories  ProductCategory[]
  products           Product[]
  outletAdmin        User              @relation(fields: [outletAdminId], references: [id])
  outletAdminId      String            @unique
  discounts          Discount[]
  updatedAt          DateTime          @updatedAt
  createdAt          DateTime          @default(now())
}

model ProductBrand {
  id              String    @id @default(cuid())
  name            String
  description     String?   @db.LongText
  brandPhoto      String?
  metaTitle       String?
  metaDescription String?   @db.LongText
  slug            String?
  outlet          Outlet    @relation(fields: [outletId], references: [id])
  outletId        String
  products        Product[]
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())
}

enum PRODUCT_CATEGORY_TYPE {
  PHYSICAL
  DIGITAL
}

model ProductCategory {
  id               String                @id @default(cuid())
  parentCategory   ProductCategory?      @relation("ParentCategoryHistory", fields: [patentCategoryId], references: [id], onDelete: SetNull)
  patentCategoryId String?
  childCategories  ProductCategory[]     @relation("ParentCategoryHistory")
  products         Product[]
  title            String
  subtitle         String?
  metaTitle        String?
  metaDescription  String?               @db.LongText
  slug             String?
  categoryType     PRODUCT_CATEGORY_TYPE @default(PHYSICAL)
  bannerPhoto      String?
  coverPhoto       String?
  icon             String?
  outlet           Outlet                @relation(fields: [outletId], references: [id])
  outletId         String
  updatedAt        DateTime              @updatedAt
  createdAt        DateTime              @default(now())
}

model Product {
  id                       String                    @id @default(cuid())
  name                     String                    @db.VarChar(255)
  shortDescription         String?                   @db.VarChar(150)
  description              String?                   @db.LongText
  isFeatured               Boolean?                  @default(false)
  isActive                 Boolean?                  @default(true)
  isNewArrival             Boolean?                  @default(false)
  isBestSeller             Boolean?                  @default(false)
  slug                     String                    @unique @db.VarChar(255)
  metaTitle                String?                   @db.VarChar(150)
  metaDescription          String?                   @db.LongText
  hasMultipleSizes         Boolean                   @default(false)
  isRefundable             Boolean?                  @default(true)
  basePrice                Decimal?
  baseStock                Int                       @default(0)
  baseSKU                  String?                   @unique
  baseBarcode              String?                   @unique
  basePackagingCost        Float?
  basePhoto                String?                   @db.VarChar(255)
  averageRating            Float?                    @default(0)
  ratingCount              Int?                      @default(0)
  productBrand             ProductBrand?             @relation(fields: [productBrandId], references: [id], onDelete: SetNull)
  productBrandId           String?
  productCategory          ProductCategory           @relation(fields: [productCategoryId], references: [id])
  productCategoryId        String
  outlet                   Outlet                    @relation(fields: [outletId], references: [id])
  outletId                 String
  frequentlyBoughtProducts FrequentlyBoughtProduct[] @relation("FrequentlyBoughtProducts")
  frequentlyBoughtBy       FrequentlyBoughtProduct[] @relation("FrequentlyBoughtProductHistory")
  productPriceAndSizes     ProductPriceAndSize[]
  productAdditionalPhotos  ProductAdditionalPhoto[]
  discountsOnProducts      DiscountsOnProducts[]
  updatedAt                DateTime                  @updatedAt
  createdAt                DateTime                  @default(now())

  @@index(fields: [isActive, isFeatured, isNewArrival, isBestSeller, name, slug])
}

model FrequentlyBoughtProduct {
  id                        String   @id @default(cuid())
  product                   Product  @relation("FrequentlyBoughtProducts", fields: [productId], references: [id])
  productId                 String
  frequentlyBoughtProduct   Product  @relation("FrequentlyBoughtProductHistory", fields: [frequentlyBoughtProductId], references: [id])
  frequentlyBoughtProductId String
  updatedAt                 DateTime @updatedAt
  createdAt                 DateTime @default(now())

  @@index(fields: [productId])
}

enum WEIGHT_UNIT {
  KILOGRAM
  POUND
  GRAM
  OUNCE
  MILLIGRAM
  TON
  MILLILITRE
  LITRE
}

enum SIZE_TYPE {
  STANDARD
  WEIGHT
}

model ProductPriceAndSize {
  id                     String       @id @default(cuid())
  sizeName               String?      @db.VarChar(50)
  sizeType               SIZE_TYPE?   @default(WEIGHT)
  weight                 Float?
  weightUnit             WEIGHT_UNIT?
  shortDescription       String?      @db.VarChar(150)
  price                  Float
  isActive               Boolean      @default(true)
  packagingCost          Float        @default(0)
  SKU                    String?      @unique @db.VarChar(100)
  barcode                String?      @unique @db.VarChar(100)
  stock                  Int          @default(0)
  lowStockThreshold      Int          @default(10)
  criticalStockThreshold Int          @default(5)
  product                Product      @relation(fields: [productId], references: [id])
  productId              String
  isFeatured             Boolean      @default(false)
  updatedAt              DateTime     @updatedAt
  createdAt              DateTime     @default(now())

  @@index([productId, sizeName, sizeType, isActive, stock])
}

model ProductAdditionalPhoto {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  photoURL  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum DISCOUNT_TYPE {
  FLAT
  PERCENT
}

model Discount {
  id                  String                @id @default(cuid())
  title               String?               @db.VarChar(150)
  discountType        DISCOUNT_TYPE         @default(PERCENT)
  flat                Float?
  percent             Float?
  startsFrom          DateTime
  endsAt              DateTime?
  outlet              Outlet                @relation(fields: [outletId], references: [id])
  outletId            String
  discountsOnProducts DiscountsOnProducts[]
  updatedAt           DateTime              @updatedAt
  createdAt           DateTime              @default(now())
}

model DiscountsOnProducts {
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  discount   Discount @relation(fields: [discountId], references: [id])
  discountId String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@id([productId, discountId])
}
