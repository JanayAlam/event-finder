generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DB_URL")
}

enum USER_ROLE {
  SUPER_ADMIN
  OUTLET_ADMIN
  CUSTOMER
}

model User {
  id            String    @id @default(cuid())
  firstName     String?
  lastName      String?
  email         String?   @unique
  phone         String?   @unique
  password      String?
  profilePhoto  String?
  isUserBlocked Boolean   @default(false)
  role          USER_ROLE @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum OTP_TYPE {
  LOGIN_EMAIL_OTP
  LOGIN_PHONE_OTP
}

model OTPDetails {
  id         String   @id @default(cuid())
  otpType    OTP_TYPE
  identifier String
  otp        String
  expireAt   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
